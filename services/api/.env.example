# GitLab Configuration
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_personal_access_token
GITLAB_PROJECT_ID=your_project_id
GITLAB_BRANCH=main
GITLAB_WORKFLOWS_PATH=.

# Application Configuration
PORT=3000
BASE_PATH=
ALLOW_PUBLISHING=true
EXPERIMENTAL_CANVAS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# OIDC / Keycloak Configuration
# If these are set, OIDC authentication will be enabled.
OIDC_ISSUER_BASE_URL=https://your-keycloak-domain/auth/realms/your-realm
OIDC_CLIENT_ID=your-client-id
OIDC_SECRET=your-client-secret-or-random-string-for-session
OIDC_BASE_URL=http://localhost:3000

# Argo & Kubernetes Configuration
ARGO_NAMESPACE=default
ARGO_SERVICE_ACCOUNT=default

# Use ARGO_SERVER_URL to submit workflows via REST API instead of direct K8s access.
# If protected by Keycloak, the user's OIDC token will be passed through.
ARGO_SERVER_URL=https://argo-workflows.hub-test.eox.at
# Optional: Provide a static token if pass-through is not possible.
# ARGO_AUTH_TOKEN=your_static_token_here

# Log Viewer (Loki) Configuration
# URL to the Loki log viewer API. Used for monitoring and fallback tracking.
LOG_VIEWER_URL=https://logviewer.domain.com/search

# Automatic Ingestion Defaults (JSON Strings)
# These are injected into workflows during save if the user confirms the prompt.
ARGO_TOLERATIONS='[{"key": "hub.eox.at/node-purpose", "operator": "Equal", "value": "worker", "effect": "NoSchedule"}]'
ARGO_NODE_SELECTOR='{"hub.eox.at/node-purpose": "worker"}'
# ARGO_AFFINITY='{}'
# ARGO_PROFILES='{"gpu": {"label": "GPU Profile", "resources": {"limits": {"nvidia.com/gpu": "1"}}}}'
