# GitLab Configuration
# Required for persisting and retrieving workflow templates
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_personal_access_token
GITLAB_PROJECT_ID=your_project_id
GITLAB_BRANCH=main
GITLAB_WORKFLOWS_PATH=.

# Application Configuration
PORT=3000
BASE_PATH=
ALLOW_PUBLISHING=true
EXPERIMENTAL_CANVAS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# LOG_VIEWER_URL=https://logviewer.domain.com/search

# Argo & Kubernetes Configuration
ARGO_NAMESPACE=default
ARGO_SERVICE_ACCOUNT=default

# Use ARGO_SERVER_URL to submit/list workflows via Argo Server REST API.
# Authentication:
# 1. ARGO_AUTH_TOKEN (if set)
# 2. Service Account Token (read from /var/run/secrets/kubernetes.io/serviceaccount/token)
# 3. User session token (passed through from the incoming request)
ARGO_SERVER_URL=https://argo-workflows.domain.com
# ARGO_AUTH_TOKEN=your_static_token_here

# Automatic Ingestion Defaults (JSON Strings)
# These are injected into workflows during save/create if applyDefaults is true.
ARGO_TOLERATIONS='[{"key": "hub.eox.at/node-purpose", "operator": "Equal", "value": "worker", "effect": "NoSchedule"}]'
ARGO_NODE_SELECTOR='{"hub.eox.at/node-purpose": "worker"}'
# ARGO_AFFINITY='{}'
# ARGO_PROFILES='{"cpu-standard": {"label": "Standard CPU", "resources": {"limits": {"cpu": "2", "memory": "4Gi"}}}}'
