GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_private_token
GITLAB_PROJECT_ID=your_project_id
GITLAB_BRANCH=main
GITLAB_WORKFLOWS_PATH=.
PORT=3000
BASE_PATH=/

# ==============================================================================
# Workflow Default Injection (Optional)
# ==============================================================================
# The backend can automatically inject default configuration into every workflow 
# YAML upon creation or save if those fields are not already defined.
# JSON-based values must be provided as single-line stringified JSON.

# Basic Settings
ARGO_NAMESPACE=default
ARGO_SERVICE_ACCOUNT=default

# Allow publishing workflow templates to pygeoapi
ALLOW_PUBLISHING=false

# Enable experimental canvas editor
EXPERIMENTAL_CANVAS=false


# Tolerations (JSON Array)
# Example: Allow scheduling on control plane nodes:
# ARGO_TOLERATIONS='[{"key": "node-role.kubernetes.io/master", "operator": "Exists", "effect": "NoSchedule"}]'
ARGO_TOLERATIONS=[]

# Node Selector (JSON Object)
# Example: Target linux nodes specifically:
# ARGO_NODE_SELECTOR='{"kubernetes.io/os": "linux"}'
ARGO_NODE_SELECTOR={}

# Affinity (JSON Object)
# Example: Require nodes in a specific node pool (e.g., userpool_a1 pool):
# ARGO_AFFINITY='{"nodeAffinity": {"requiredDuringSchedulingIgnoredDuringExecution": {"nodeSelectorTerms": [{"matchExpressions": [{"key": "cce.cloud.com/cce-nodepool", "operator": "In", "values": ["userpool_a1"]}]}]}}}'
ARGO_AFFINITY={}

# ==============================================================================
# Resource Profiles (Optional)
# ==============================================================================
# Define pre-configured resource profiles for users to select during workflow creation.
# This must be a valid JSON object string mapping profile IDs to their configurations.
# 
# Example Profiles Configuration:
# ARGO_PROFILES='{
#   "cpu-standard": {
#     "label": "Standard CPU (2 CPU, 4Gi RAM)",
#     "resources": { "limits": { "cpu": "2", "memory": "4Gi" }, "requests": { "cpu": "500m", "memory": "1Gi" } }
#   },
#   "cpu-performance": {
#     "label": "Performance CPU (10 CPU, 48Gi RAM)",
#     "resources": { "limits": { "cpu": "10", "memory": "48Gi" }, "requests": { "cpu": "5", "memory": "24Gi" } }
#   },
#   "gpu-nvidia": {
#     "label": "NVIDIA GPU (1 GPU, 4 CPU, 16Gi RAM)",
#     "resources": { "limits": { "nvidia.com/gpu": "1", "cpu": "4", "memory": "16Gi" } },
#     "tolerations": [ { "key": "nvidia.com/gpu", "operator": "Exists", "effect": "NoSchedule" } ]
#   }
# }'

